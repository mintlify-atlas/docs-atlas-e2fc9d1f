  "keyFeatures": [
    "Type-safe Pydantic models for all API responses",
    "Sync and async clients with identical APIs",
    "Automatic retries with exponential backoff",
    "Multiple authentication flows (access token, client credentials, authorization code)",
    "Context manager support for clean resource management",
    "Token caching with pluggable interface"
  ],
